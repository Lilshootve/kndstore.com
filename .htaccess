# KND Store - Configuración Apache Optimizada

# Habilitar compresión GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Configuración de cache del navegador
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Imágenes
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # CSS y JavaScript
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"
    
    # Fuentes
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    
    # HTML
    ExpiresByType text/html "access plus 1 hour"
    
    # Otros
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType application/x-shockwave-flash "access plus 1 month"
</IfModule>

# Headers de seguridad
<IfModule mod_headers.c>
    # Pages that run Three.js + meshopt WASM (model-viewer, hologram lab, squad arena GLB)
    SetEnvIf Request_URI "^/viewer/" KND_VIEWER_PAGE
    SetEnvIf Request_URI "^/tools/hologram-lab/" KND_VIEWER_PAGE
    SetEnvIf Request_URI "^/squad-arena-v2/" KND_VIEWER_PAGE

    # Protección XSS
    Header always set X-XSS-Protection "1; mode=block"
    
    # Prevenir MIME sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # Prevenir clickjacking: permitir iframes solo mismo origen (Labs → /viewer/)
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Permissions Policy
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    
    # HSTS (HTTP Strict Transport Security)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    
    # Content Security Policy: viewer needs wasm-unsafe-eval + unpkg for Three.js/GLB
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' blob: https://unpkg.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com https://code.jquery.com https://www.paypal.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net data:; img-src 'self' data: blob: https: https://www.paypalobjects.com; media-src 'self' data: blob:; frame-src 'self' https://www.paypal.com https://www.sandbox.paypal.com; connect-src 'self' blob: https://unpkg.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com https://fonts.gstatic.com https://www.paypal.com https://www.paypalobjects.com https://api-m.paypal.com;" env=KND_VIEWER_PAGE
    # Content Security Policy (rest of site, includes PayPal LIVE)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' blob: https://unpkg.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com https://code.jquery.com https://www.paypal.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net data:; img-src 'self' data: blob: https: https://www.paypalobjects.com; media-src 'self' data: blob:; frame-src 'self' https://www.paypal.com https://www.sandbox.paypal.com; connect-src 'self' blob: https://unpkg.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com https://fonts.gstatic.com https://www.paypal.com https://www.paypalobjects.com https://api-m.paypal.com;" env=!KND_VIEWER_PAGE
    
    # Service Worker Scope
    <Files "sw.js">
        Header always set Service-Worker-Allowed "/"
    </Files>
</IfModule>

# Configuración de cache para archivos estáticos
<FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Configuración de cache para HTML estático
<FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600"
</FilesMatch>

# PHP: no cachear por defecto (cada script controla su propio cache via header())
<FilesMatch "\.php$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Redirección de HTTP a HTTPS
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Redirigir HTTP a HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Redirigir www a no-www
    RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

    # KND Arena friendly URL
    RewriteRule ^arena/?$ /knd-arena.php [L]

    # Legacy Mind Wars Squad Arena (v1) -> v2
    # Keep v2 as the only implementation; legacy routes now just redirect.
    RewriteRule ^squad-arena/mind-wars-select\.php$ /squad-arena-v2/squad-selector.php [R=301,L]
    RewriteRule ^squad-arena/squad-arena\.php$ /squad-arena-v2/squad-selector.php [R=301,L]
    RewriteRule ^squad-arena/battle-launcher\.php$ /squad-arena-v2/squad-selector.php [R=301,L]
    RewriteRule ^squad-arena/battle-result\.php$ /squad-arena-v2/squad-selector.php [R=301,L]
    RewriteRule ^squad-arena/.*$ /squad-arena-v2/squad-selector.php [R=301,L]

    # KND Drop (Neural Link — current drop; knd-drop.php is legacy)
    RewriteRule ^drop/?$ /games/knd-neural-link/drops.php [L]

    # KND LastRoll friendly URLs
    RewriteRule ^lastroll/?$ /death-roll-lobby.php [L]
    RewriteRule ^lastroll/game/?$ /death-roll-game.php [QSA,L]

    # Support Credits friendly URLs
    RewriteRule ^credits/?$ /support-credits.php [L]
    RewriteRule ^rewards/?$ /rewards.php [L]

    # Game Fairness
    RewriteRule ^game-fairness/?$ /game-fairness.php [L]

    # How KND Arena Works
    RewriteRule ^how-knd-arena-works/?$ /how-knd-arena-works.php [L]

    # Character Lab (standalone route)
    RewriteRule ^character-lab/?$ /labs-character-lab.php [L]

    # KND Labs Next (experimental app-style UI)
    RewriteRule ^labs-next/?$ /labs-next.php [L]

    # KND Labs: app shell (new UI) + legacy hub backup
    RewriteRule ^labs-legacy/?$ /knd-labs-legacy.php [L]
    RewriteRule ^labs/?$ /knd-labs.php [L]
    RewriteRule ^knd-labs/?$ /knd-labs.php [L]
    RewriteRule ^labs/text-to-image\.php$ /labs-text-to-image.php [L]
    RewriteRule ^labs/upscale\.php$ /labs-upscale.php [L]
    RewriteRule ^labs/consistency\.php$ /labs-consistency.php [L]
    RewriteRule ^labs/character-lab\.php$ /labs-character-lab.php [L]
    RewriteRule ^labs/texture-lab\.php$ /labs-texture-lab.php [L]
    RewriteRule ^labs/3D-Lab\.php$ /labs-3d-lab.php [L]
    RewriteRule ^labs/3d-lab/?$ /labs-3d-lab.php [L]
    RewriteRule ^labs/jobs\.php$ /labs-jobs.php [L]
    RewriteRule ^labs/job\.php$ /labs-job.php [L]

    # Hologram viewer (unified)
    RewriteRule ^hologram-viewer\.html$ /tools/hologram-lab/index.html [L,R=301]
    RewriteRule ^hologram-lab/?$ /tools/hologram-lab/index.html [L]
</IfModule>

# Configuración de compresión adicional
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json
</IfModule>

# Configuración de seguridad adicional
<IfModule mod_rewrite.c>
    # Bloquear acceso a archivos sensibles
    RewriteRule ^(config\.php|config-local\.php|\.env|\.htaccess|\.git) - [F,L]
    
    # Bloquear acceso a directorios sensibles
    RewriteRule ^(includes|cache|backups|logs)/ - [F,L]
    
    # Bloquear acceso a archivos de backup
    RewriteRule \.(bak|backup|old|tmp|temp)$ - [F,L]
</IfModule>

# Configuración de PHP
<IfModule mod_php.c>
    # Configuración de memoria
    php_value memory_limit 256M
    
    # Configuración de tiempo de ejecución
    php_value max_execution_time 30
    
    # Configuración de upload
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    
    # Configuración de sesiones (24h para evitar cierre prematuro)
    php_value session.gc_maxlifetime 86400
    php_value session.cookie_httponly 1
    php_value session.use_only_cookies 1
    php_value session.cookie_secure 1
    php_value session.cookie_samesite "Lax"
</IfModule>

# Configuración de error pages
ErrorDocument 404 /404.html
ErrorDocument 500 /500.html

# Configuración de MIME types
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType text/css .css
    AddType image/svg+xml .svg
    AddType model/gltf-binary .glb
    AddType application/font-woff .woff
    AddType application/font-woff2 .woff2
    AddType application/x-font-ttf .ttf
    AddType application/x-font-otf .otf
</IfModule>

# Configuración de compresión para archivos específicos
<FilesMatch "\.(css|js|html|php|xml|txt)$">
    <IfModule mod_deflate.c>
        SetOutputFilter DEFLATE
    </IfModule>
</FilesMatch>

# Configuración de cache para Service Worker
<FilesMatch "sw\.js$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
</FilesMatch>

# Configuración de cache para manifest
<FilesMatch "site\.webmanifest$">
    Header set Cache-Control "public, max-age=86400"
</FilesMatch>

# Configuración de seguridad para archivos de imagen
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg)$">
    Header set X-Content-Type-Options "nosniff"
</FilesMatch>

# Configuración de compresión para fuentes
<FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
    <IfModule mod_deflate.c>
        SetOutputFilter DEFLATE
    </IfModule>
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch> 